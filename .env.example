# ─── NutriGenix Environment Configuration ───────────────────────────
# Copy this file to .env and fill in values
# NEVER commit .env to git

# ── Services ──────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=nutrigenix123

DATABASE_URL=postgresql://nutrigenix:nutrigenix123@localhost:5432/nutrigenix_db

MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=nutrigenix_deficiency_model

# ── Local LLM (Ollama) ────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral:7b-instruct-q4_K_M   # Fits in 6GB VRAM

# ── Vector Store ──────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./vector_store/chroma
CHROMA_COLLECTION_NAME=pubmed_nutrition

# ── Embeddings Model (runs locally, no API key needed) ────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── Free External APIs ────────────────────────────────────────────
PUBMED_API_KEY=                 # Optional — increases rate limit (sign up free at NCBI)
USDA_API_KEY=DEMO_KEY           # Free — get your key at api.nal.usda.gov
OPENFDA_API_KEY=                # Optional — free at open.fda.gov

# ── App Settings ──────────────────────────────────────────────────
LOG_LEVEL=INFO
MAX_UPLOAD_SIZE_MB=20
REPORT_OUTPUT_DIR=./data/reports
MODEL_DIR=./models

# ── MLOps ─────────────────────────────────────────────────────────
DRIFT_ALERT_THRESHOLD=0.15      # Alert if data drift score exceeds this
MODEL_CONFIDENCE_THRESHOLD=0.60 # Minimum confidence to include recommendation
